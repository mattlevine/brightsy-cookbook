BRIGHTSY_API_KEY=bsy_your_key_here
BRIGHTSY_ACCOUNT_ID=your-account-uuid
# BRIGHTSY_RECORD_TYPE_SLUG=posts
# BRIGHTSY_RECORD_ID=uuid
# BRIGHTSY_RECORD_IDS=uuid1,uuid2

# Advanced filters (optional — must match fields on your record type)
# BRIGHTSY_FILTER_FIELD=status
# BRIGHTSY_FILTER_OP=eq
# BRIGHTSY_FILTER_VALUE=published
# BRIGHTSY_RECORD_TAG=featured
# BRIGHTSY_SELECT_FIELDS=id,title,updated_at

# Aggregates (optional — numeric / group field must exist on your type)
# BRIGHTSY_AGG_SUM_FIELD=amount
# BRIGHTSY_AGG_AVG_FIELD=amount
# BRIGHTSY_AGG_GROUP_BY=category_id

# Natural language on CDA
# BRIGHTSY_TRY_NL=1
# BRIGHTSY_NL_QUERY=quarterly goals
# BRIGHTSY_NL_THRESHOLD=0.7
# BRIGHTSY_NL_TIME_DECAY_DAYS=30
# BRIGHTSY_NL_LIMIT=8

# BRIGHTSY_VERBOSE=1
